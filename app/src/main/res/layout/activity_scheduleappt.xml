<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".scheduleappt">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        >

        <TextView
            android:id="@+id/expenditure_report_head"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="sans-serif-medium"
            android:padding="10dp"
            android:text="Schedule an Appointment"
            android:textColor="#000000"
            android:textSize="25sp"
            android:background="#ffa81e"/>

        <com.toptoche.searchablespinnerlibrary.SearchableSpinner
            android:id="@+id/spinner"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="24dp"
            android:paddingLeft="10dp"
            android:background="@drawable/expenditure_input_border"
            />


        <TextView
            android:id="@+id/date_appointment"
            android:layout_width="350dp"
            android:layout_height="60dp"
            android:layout_margin="14dp"
            android:text="Date"
            android:textSize="20sp"
            style="?android:spinnerStyle"
            android:onClick="openDatePicker"
            android:paddingLeft="10dp"
            android:textColor="#A9A9A9"
            android:background="@drawable/expenditure_input_border"/>

        <TextView
            android:id="@+id/time_appointment"
            android:layout_width="350dp"
            android:layout_height="60dp"
            android:layout_margin="14dp"
            android:text="Time"
            android:textSize="20sp"
            android:textColor="#A9A9A9"
            style="?android:spinnerStyle"
            android:background="@drawable/expenditure_input_border"
            android:paddingLeft="10dp"
            android:onClick="popTimePicker" />

        <EditText
            android:id="@+id/reason_tv"
            android:layout_width="350dp"
            android:layout_height="177dp"
            android:layout_margin="14dp"
            android:background="@drawable/expenditure_input_border"
            android:gravity="top"
            android:hint="Details"
            android:padding="10dp"
            android:textColor="#000000"
            android:textSize="20dp" />

        <Button
            android:id="@+id/schedule_appointment_btn"
            android:layout_width="158dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="100dp"
            android:layout_marginTop="15dp"
            android:layout_marginRight="100dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/custom_button"
            android:fontFamily="sans-serif-medium"
            android:text="Schedule"
            android:textSize="20dp" />

    </LinearLayout>




</ScrollView>