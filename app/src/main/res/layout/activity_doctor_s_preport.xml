<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".doctor_s_preport">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.toptoche.searchablespinnerlibrary.SearchableSpinner
            android:id="@+id/spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="34dp"
            android:background="@drawable/expenditure_input_border" />




        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/spinner"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:id="@+id/displayreport"
            android:visibility="gone">


            <TextView
                android:id="@+id/my_report_head"
                android:layout_width="232dp"
                android:layout_height="match_parent"
                android:fontFamily="sans-serif-medium"
                android:padding="6dp"
                android:text="Patient Report"
                android:textColor="#000000"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/name_tv_main"
                android:layout_width="match_parent"
                android:layout_height="41dp"
                android:background="#ffecbf"
                android:fontFamily="sans-serif-medium"
                android:padding="4dp"
                android:text="Name"
                android:textColor="#000000"
                android:textSize="25sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="155dp"
                android:padding="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="125dp"
                    android:layout_margin="10dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#ffa81e"
                    app:cardElevation="10dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10sp">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerHorizontal="true"
                            android:src="@drawable/height_logo" />

                        <TextView
                            android:id="@+id/height_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:fontFamily="sans-serif-medium"
                            android:includeFontPadding="false"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/height"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/height_no"
                            android:layout_centerHorizontal="true"
                            android:layout_marginTop="7dp"
                            android:fontFamily="sans-serif-medium"
                            android:includeFontPadding="false"
                            android:text="Height"
                            android:textSize="14sp" />


                    </RelativeLayout>


                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="125dp"
                    android:layout_margin="10dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#ffa81e"
                    app:cardElevation="10dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10sp">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerHorizontal="true"
                            android:src="@drawable/weight_logo" />

                        <TextView
                            android:id="@+id/weight_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:fontFamily="sans-serif-medium"
                            android:includeFontPadding="false"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/weight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/weight_no"
                            android:layout_centerHorizontal="true"
                            android:layout_marginTop="7dp"
                            android:fontFamily="sans-serif-medium"
                            android:includeFontPadding="false"
                            android:text="Weight"
                            android:textSize="14sp" />


                    </RelativeLayout>


                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="125dp"
                    android:layout_margin="10dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#ffa81e"
                    app:cardElevation="10dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10sp">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerHorizontal="true"
                            android:src="@drawable/age_logo" />

                        <TextView
                            android:id="@+id/age_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:fontFamily="sans-serif-medium"
                            android:includeFontPadding="false"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/age"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/age_no"
                            android:layout_centerHorizontal="true"
                            android:layout_marginTop="7dp"
                            android:fontFamily="sans-serif-medium"
                            android:includeFontPadding="false"
                            android:text="Age"
                            android:textSize="14sp" />


                    </RelativeLayout>


                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="125dp"
                    android:layout_margin="10dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#ffa81e"
                    app:cardElevation="10dp">

                    <RelativeLayout
                        android:id="@+id/bmi_layout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="1sp">

                        <ImageView
                            android:id="@+id/bmi_logo"
                            android:layout_width="30dp"
                            android:layout_height="28dp"
                            android:layout_centerHorizontal="true"
                            android:layout_marginTop="5dp" />

                        <TextView
                            android:id="@+id/bmi_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/bmi_logo"
                            android:layout_centerHorizontal="true"
                            android:layout_marginTop="7dp"
                            android:fontFamily="sans-serif-medium"
                            android:includeFontPadding="false"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/bmi_cat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/bmi_no"
                            android:layout_centerHorizontal="true"
                            android:layout_marginTop="7dp"
                            android:fontFamily="sans-serif-medium"
                            android:includeFontPadding="false"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/bmi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/bmi_cat"
                            android:layout_centerHorizontal="true"
                            android:layout_marginTop="11dp"
                            android:fontFamily="sans-serif-medium"
                            android:includeFontPadding="false"
                            android:text="BMI"
                            android:textSize="14sp" />


                    </RelativeLayout>


                </com.google.android.material.card.MaterialCardView>


            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:text="Patient's Assessments"
                android:textSize="20sp"
                android:textColor="#000000"
                android:padding="4dp"
                android:fontFamily="sans-serif-medium"
                android:background="#ffdb87"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:id="@+id/covid_tv"
                    android:padding="5dp">


                    <RelativeLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="#d7ff8c"
                        android:elevation="8dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/covid_image"
                            android:layout_centerInParent="true"></ImageView>


                    </RelativeLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Covid-19"
                        android:textAlignment="center"
                        android:textColor="#474242"
                        android:gravity="center_horizontal"/>


                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:layout_marginLeft="50dp"
                    android:layout_marginRight="50dp"
                    android:id="@+id/influenza_tv">


                    <RelativeLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="#fbb3fc"
                        android:elevation="8dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/influenza_image"
                            android:layout_centerInParent="true"></ImageView>


                    </RelativeLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Influenza"
                        android:textAlignment="center"
                        android:textColor="#474242"
                        android:gravity="center_horizontal"/>


                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:id="@+id/stress_tv">


                    <RelativeLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="#b8fffb"
                        android:elevation="8dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/stress_image"
                            android:layout_centerInParent="true"></ImageView>


                    </RelativeLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Stress"
                        android:textAlignment="center"
                        android:textColor="#474242"
                        android:gravity="center_horizontal"/>


                </LinearLayout>



            </LinearLayout>

            <TextView
                android:id="@+id/recent_reports_tv"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#ffecbf"
                android:fontFamily="sans-serif-medium"
                android:padding="4dp"
                android:layout_marginBottom="10dp"
                android:text="No Reports"
                android:textColor="#000000"
                android:textSize="22sp" />

            <!--<LinearLayout
                android:id="@+id/recent_reports_LL"
                android:layout_width="372dp"
                android:layout_height="80dp"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="15dp"
                android:orientation="vertical">


                <TextView
                    android:id="@+id/noreport"
                    android:layout_width="356dp"
                    android:layout_height="match_parent"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/white_custom_button"
                    android:fontFamily="sans-serif-medium"
                    android:padding="4dp"
                    android:text="@string/no_recent_reports"
                    android:textColor="#000000"
                    android:textSize="25sp" />

            </LinearLayout>-->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewiz"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewcd"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />


        </LinearLayout>



    </RelativeLayout>
</ScrollView>