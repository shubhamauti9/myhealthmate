<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".medicationreminder">




    <TextView
        android:id="@+id/head"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="5dp"
        android:layout_marginRight="5dp"
        android:background="@drawable/custom_button"
        android:fontFamily="sans-serif-medium"
        android:paddingLeft="15dp"
        android:paddingTop="7dp"
        android:paddingBottom="8dp"
        android:text="Medication Reminder"
        android:textColor="@color/common_google_signin_btn_text_dark_focused"
        android:textSize="30sp"
        android:textStyle="normal" />



    <Button
        android:id="@+id/button_timepicker"
        android:layout_width="267dp"

        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_marginStart="22dp"
        android:layout_marginLeft="22dp"
        android:layout_marginTop="278dp"
        android:layout_marginEnd="106dp"
        android:layout_marginRight="106dp"
        android:text="Open Time Picker"
        android:textSize="16dp"/>

    <LinearLayout
        android:layout_width="366dp"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginTop="112dp"
        android:orientation="vertical"
        android:background="@drawable/custom_button"
        android:backgroundTint="#ffecbf"
        android:padding="5dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="7dp"
            android:text="Medicine Days"
            android:textColor="@color/design_default_color_on_secondary" />

        <CheckBox
            android:id="@+id/every_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EveryDay" />


        <LinearLayout
            android:id="@+id/checkbox_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="7">

            <CheckBox
                android:id="@+id/dv_sunday"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:background="@drawable/background_day_view"
                android:button="@null"
                android:gravity="center"
                android:text="S" />

            <CheckBox
                android:id="@+id/dv_monday"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:background="@drawable/background_day_view"
                android:button="@null"
                android:gravity="center"
                android:text="M" />


            <CheckBox
                android:id="@+id/dv_tuesday"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:background="@drawable/background_day_view"
                android:button="@null"
                android:gravity="center"
                android:text="T" />

            <CheckBox
                android:id="@+id/dv_wednesday"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:background="@drawable/background_day_view"
                android:button="@null"
                android:gravity="center"
                android:text="W" />

            <CheckBox
                android:id="@+id/dv_thursday"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:background="@drawable/background_day_view"
                android:button="@null"
                android:gravity="center"
                android:text="T" />

            <CheckBox
                android:id="@+id/dv_friday"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:background="@drawable/background_day_view"
                android:button="@null"
                android:gravity="center"
                android:text="F" />


            <CheckBox
                android:id="@+id/dv_saturday"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:background="@drawable/background_day_view"
                android:button="@null"
                android:gravity="center"
                android:text="S" />


        </LinearLayout>

    </LinearLayout>

    <EditText
        android:id="@+id/medicine"
        android:layout_width="295dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/button_timepicker"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="27dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="73dp"
        android:ems="10"
        android:gravity="start|top"
        android:hint="Enter Medicine name"
        android:inputType="textMultiLine" />

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="400dp"
    android:layout_below="@+id/medicine"
    android:padding="50dp"
    android:gravity="center_horizontal">

    <Button
        android:id="@+id/add"
        android:layout_width="84dp"
        android:layout_height="54dp"
        android:layout_below="@+id/medicine"
        android:text="Add"
        android:textSize="16dp"/>

    <Button
        android:id="@+id/list"
        android:layout_width="84dp"
        android:layout_height="54dp"
        android:layout_below="@+id/medicine"
        android:layout_marginLeft="30dp"
        android:text="List"
        android:textSize="16dp"/>

</LinearLayout>



</RelativeLayout>

