<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".expense">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
       >

        <TextView
            android:id="@+id/schedule_appointment_head"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="sans-serif-medium"
            android:padding="10dp"
            android:text="Expenditure"
            android:textColor="#000000"
            android:textSize="25sp"/>

        <TextView
            android:id="@+id/name_tv_main_SA"
            android:layout_width="match_parent"
            android:layout_height="41dp"
            android:background="#ffa81e"
            android:fontFamily="sans-serif-medium"
            android:paddingLeft="10dp"
            android:text="Name"
            android:textColor="#000000"
            android:textSize="25sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

        <EditText
            android:id="@+id/detail_tv"
            android:layout_width="340dp"
            android:layout_height="155dp"
            android:layout_margin="14dp"
            android:background="@drawable/expenditure_input_border"
            android:gravity="top"
            android:hint="Details of Expense"
            android:padding="10dp"
            android:textColor="#000000"
            android:textSize="20dp" />

        <EditText
            android:id="@+id/amount_tv"
            android:layout_width="340dp"
            android:layout_height="58dp"
            android:layout_margin="14dp"
            android:background="@drawable/expenditure_input_border"
            android:gravity="left"
            android:hint="Amount in Rupees"
            android:inputType="number"
            android:padding="10dp"
            android:textColor="#000000"
            android:textSize="20dp" />

        <TextView
            android:id="@+id/date_appointment"
            android:layout_width="340dp"
            android:layout_height="60dp"
            android:layout_margin="14dp"
            android:text="Date"
            android:textSize="20sp"
            android:textColor="#A9A9A9"
            style="?android:spinnerStyle"
            android:onClick="openDatePicker"
            android:background="@drawable/expenditure_input_border"
            android:paddingLeft="10dp"
            />

        </LinearLayout>

        <Button
            android:id="@+id/add_expense_btn"
            android:layout_width="158dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="100dp"
            android:layout_marginTop="15dp"
            android:layout_marginRight="100dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/custom_button"
            android:fontFamily="sans-serif-medium"
            android:text="ADD"
            android:textSize="20dp"
            />

        <Button
            android:id="@+id/add_expense_btn2"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="100dp"
            android:layout_marginTop="15dp"
            android:layout_marginRight="100dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/custom_button"
            android:fontFamily="sans-serif-medium"
            android:text="View Records"
            android:textSize="20dp" />

    </LinearLayout>

</ScrollView>