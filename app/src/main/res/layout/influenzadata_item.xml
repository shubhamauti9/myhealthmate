<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        tools:ignore="MissingConstraints">


        <TableLayout
            android:padding="10dp"
            android:background="@drawable/custom_button"
            android:backgroundTint="#ffecbf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:gravity="center_horizontal">

            <TableRow>
                <TextView
                    android:id="@+id/influenza"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Influenza Report"
                    android:textColor="#000"
                    android:textSize="15dp"
                    />
            </TableRow>


            <TableRow>

                <TextView
                    android:id="@+id/date_r_iz"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date_Time:" />

                <TextView
                    android:id="@+id/date_db_iz"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />
            </TableRow>

            <TableRow>

                <TextView
                    android:id="@+id/age_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Age" />

                <TextView
                    android:id="@+id/age_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />



            </TableRow>

            <TableRow>

                <TextView
                    android:id="@+id/cough_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cough" />

                <TextView
                    android:id="@+id/cough_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />

            </TableRow>

            <TableRow>

                <TextView
                    android:id="@+id/fatigue_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fatigue" />

                <TextView
                    android:id="@+id/fatigue_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />

            </TableRow>


            <TableRow>

                <TextView
                    android:id="@+id/fever_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fever" />

                <TextView
                    android:id="@+id/fever_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />

            </TableRow>

            <TableRow>


                <TextView
                    android:id="@+id/headache_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Headache" />

                <TextView
                    android:id="@+id/headache_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />

            </TableRow>

            <TableRow>

                <TextView
                    android:id="@+id/medicalcond_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medical Condition" />


                <TextView
                    android:id="@+id/medicalcond_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />

            </TableRow>

            <TableRow>



                <TextView
                    android:id="@+id/myalgia_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Myalgia" />

                <TextView
                    android:id="@+id/myalgia_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />

            </TableRow>

            <TableRow>

                <TextView
                    android:id="@+id/runnynose_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Runny Nose" />

                <TextView
                    android:id="@+id/runnynose_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />

            </TableRow>

            <TableRow>

                <TextView
                    android:id="@+id/throatache_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ThroatAche" />

                <TextView
                    android:id="@+id/throatache_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />

            </TableRow>

            <TableRow>

                <TextView
                    android:id="@+id/vomiting_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vomiting" />

                <TextView
                    android:id="@+id/vomiting_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />

            </TableRow>

            <TableRow>





                <TextView
                    android:id="@+id/result_r_iz"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Result" />

                <TextView
                    android:id="@+id/result_db_iz"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />


            </TableRow>




        </TableLayout>



    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>