<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".connectDoctor"
    android:orientation="vertical">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        >


        <ImageView
            android:id="@+id/mini_logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/mini_logo"
            android:layout_centerVertical="true"/>

        <TextView
            android:layout_marginLeft="20dp"
            android:layout_width="200dp"
            android:layout_height="40dp"
            android:layout_toRightOf="@+id/mini_logo"
            android:text="Connect"
            android:textSize="30sp"
            android:fontFamily="sans-serif-medium"/>

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="#ffa81e">

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageView
            android:id="@+id/doctorNewIcon"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/doctor_icon"
            android:layout_centerHorizontal="true"
            >

        </ImageView>

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:layout_marginLeft="20dp"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:id="@+id/text1"
            android:text="Enter Your Doctor's Username"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text1"
            android:id="@+id/docUsername"
            android:hint="User Name"
            android:layout_marginTop="5dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">


            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                />

        </com.google.android.material.textfield.TextInputLayout>






    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            >
            <Button
                android:id="@+id/checkButton"
                android:layout_width="90dp"
                android:layout_height="50dp"
                android:text="Check"/>

            <Button
                android:layout_marginLeft="30dp"
                android:layout_toRightOf="@id/checkButton"
                android:id="@+id/sendButton"
                android:layout_width="180dp"
                android:layout_height="50dp"
                android:text="Send Request"/>


        </RelativeLayout>

    </RelativeLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp">

        <TextView
            android:id="@+id/Status"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:text=""
            android:textColor="#0C850E"
            android:textSize="16.5dp"
            android:textStyle="bold"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/docName"
            android:text=""
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:textSize="20dp"
            android:visibility="invisible"/>
        <TextView
            android:id="@+id/docEmail"
            android:text=""
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:textSize="20dp"
            android:visibility="invisible"/>
        <TextView
            android:id="@+id/docPhoneNo"
            android:text=""
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:textSize="20dp"
            android:visibility="invisible"/>

        <TextView
            android:id="@+id/docRes"
            android:text=""
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:textSize="20dp"
            android:visibility="invisible"/>



    </LinearLayout>




</LinearLayout>